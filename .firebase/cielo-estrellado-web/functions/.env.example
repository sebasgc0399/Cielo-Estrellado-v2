# Copy this file to .env.local and fill the values needed in your machine.

APP_URL=http://localhost:3000
SESSION_COOKIE_NAME=cielo_session

# Firestore Admin (legacy scripts + runtime auth/session)
# Use a local JSON file path. Keep the JSON outside Git.
FIREBASE_SERVICE_ACCOUNT_PATH=./scripts/serviceAccountKey.json

# Legacy migration scripts only (Admin SDK)
# Must match the same Firebase project used by FIREBASE_SERVICE_ACCOUNT_PATH.
FIREBASE_STORAGE_BUCKET=

# Legacy audit: Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Runtime Firebase config (required for auth)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
